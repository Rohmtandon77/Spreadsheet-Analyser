# vLLM model server
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B

# API server
API_HOST=0.0.0.0
API_PORT=8080

# Postgres (job metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spreadsheet_analysis
POSTGRES_USER=sa_user
POSTGRES_PASSWORD=changeme

# Redis (job queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Data paths
DATA_DIR=./data
UPLOAD_MAX_SIZE_MB=50

# Sandbox
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_RETRIES=2

# GPU allocation (for reference)
# GPUs 0-3: DeepSeek via vLLM (tp=4)
# GPU 4: Whisper STT
# GPU 5: TTS
# GPUs 6-7: free
